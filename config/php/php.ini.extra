; ~/.php.ini.extra — personal PHP overrides
; Load with: php -c ~/.php.ini.extra

memory_limit = 512M
max_execution_time = 120
upload_max_filesize = 64M
post_max_size = 64M
display_errors = On
display_startup_errors = On
error_reporting = E_ALL

; Xdebug 3 config (for local dev)
[xdebug]
xdebug.mode = debug
xdebug.start_with_request = yes
xdebug.client_host = 127.0.0.1
xdebug.client_port = 9003
xdebug.log_level = 0
